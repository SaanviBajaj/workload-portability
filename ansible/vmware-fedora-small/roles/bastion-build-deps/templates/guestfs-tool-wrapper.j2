#!/bin/bash
# Prefer host binary; otherwise run inside {{ guestfs_image }}.
set -euo pipefail

TOOL="$(basename "$0")"
HOST_BIN=""
for candidate in "/usr/bin/${TOOL}" "/bin/${TOOL}" "/usr/sbin/${TOOL}"; do
  if [[ -x "${candidate}" ]]; then
    HOST_BIN="${candidate}"
    break
  fi
done

if [[ -n "${HOST_BIN}" ]]; then
  exec "${HOST_BIN}" "$@"
fi

exec podman run --rm --privileged --network host \
  --security-opt label=disable \
  -e LIBGUESTFS_BACKEND=direct \
  -e HOME=/root \
  -v "{{ work_base }}:{{ work_base }}" \
  -v /var/tmp:/var/tmp \
  -v /tmp:/tmp \
  -w "{{ work_base }}" \
  "{{ guestfs_image }}" \
  "${TOOL}" "$@"
