#!/bin/bash
# Repack customized Fedora Cloud Base into a UEFI disk of size DISK_MB.
# Stock Cloud Base is ~5 GiB virtual with a ~1 GiB /boot — virt-resize alone
# cannot reach a small disk_mb. This copies ESP+/boot+/ (+ /var,/home) onto a
# new GPT layout.
#
# Usage: repack-disk.sh SRC_QCOW DST_QCOW DISK_MB MIN_FREE_MB EFI_MB BOOT_MB
set -euo pipefail

SRC="${1:?src qcow}"
DST="${2:?dst qcow}"
DISK_MB="${3:?disk_mb}"
MIN_FREE_MB="${4:?min_free_mb}"
EFI_MB="${5:?efi_mb}"
BOOT_MB="${6:?boot_mb}"

export LIBGUESTFS_BACKEND="${LIBGUESTFS_BACKEND:-direct}"

WORK="$(cd "$(dirname "$DST")" && pwd)"
ROOT_TAR="$WORK/rootfs.tar"
BOOT_TAR="$WORK/bootfs.tar"
EFI_TAR="$WORK/efifs.tar"
VAR_TAR="$WORK/varfs.tar"
HOME_TAR="$WORK/homefs.tar"
MEASURE_OUT="$WORK/measure.txt"
DISK_MB_MAX="{{ disk_mb_max }}"

rm -f "$DST" "$ROOT_TAR" "$BOOT_TAR" "$EFI_TAR" "$VAR_TAR" "$HOME_TAR" "$MEASURE_OUT"

echo "=== Measuring source filesystems ==="
virt-df -h -a "$SRC" | tee "$MEASURE_OUT"
virt-df -a "$SRC" --csv | tee "$WORK/measure.csv"

# virt-df --csv: Filesystem,Type,Size,Used,Available,Use%,Mountpoint (1K-blocks)
USED_ROOT_MB="$(awk -F, '
  NR > 1 && $NF == "/" {
    used_kb = $4 + 0
    if (used_kb > best) best = used_kb
  }
  END {
    if (best > 0) printf "%d", int(best / 1024) + 1
  }
' "$WORK/measure.csv")"

USED_BOOT_MB="$(awk -F, '
  NR > 1 && $NF == "/boot" {
    printf "%d", int(($4 + 0) / 1024) + 1
    exit
  }
' "$WORK/measure.csv")"
USED_BOOT_MB="${USED_BOOT_MB:-0}"

if [[ -z "${USED_ROOT_MB}" || "${USED_ROOT_MB}" -le 0 ]]; then
  USED_ROOT_MB="$(awk -F, '
    NR > 1 {
      used_kb = $4 + 0
      if (used_kb > 200 * 1024 && used_kb > best) best = used_kb
    }
    END {
      if (best > 0) printf "%d", int(best / 1024) + 1
    }
  ' "$WORK/measure.csv")"
fi

if [[ -z "${USED_ROOT_MB}" || "${USED_ROOT_MB}" -le 0 ]]; then
  echo "ERROR: could not measure used space on / from source image" >&2
  cat "$WORK/measure.csv" >&2 || true
  exit 1
fi

echo "=== Exporting filesystems (virt-tar-out) ==="
# Cloud Base uses btrfs subvolumes for /var and /home — must export separately
# or the preloaded containers under /var/lib/containers are dropped.
virt-tar-out -a "$SRC" /boot/efi "$EFI_TAR"
virt-tar-out -a "$SRC" /boot "$BOOT_TAR"
virt-tar-out -a "$SRC" / "$ROOT_TAR"

HAVE_VAR=0
HAVE_HOME=0
if virt-tar-out -a "$SRC" /var "$VAR_TAR"; then
  HAVE_VAR=1
else
  rm -f "$VAR_TAR"
fi
if virt-tar-out -a "$SRC" /home "$HOME_TAR"; then
  HAVE_HOME=1
else
  rm -f "$HOME_TAR"
fi

ROOT_TAR_MB="$(du -m "$ROOT_TAR" | awk '{print $1}')"
VAR_TAR_MB=0
HOME_TAR_MB=0
BOOT_TAR_MB="$(du -m "$BOOT_TAR" | awk '{print $1}')"
if [[ "$HAVE_VAR" -eq 1 ]]; then
  VAR_TAR_MB="$(du -m "$VAR_TAR" | awk '{print $1}')"
fi
if [[ "$HAVE_HOME" -eq 1 ]]; then
  HOME_TAR_MB="$(du -m "$HOME_TAR" | awk '{print $1}')"
fi
# Uncompressed tar ≈ data that will land on ext4 (btrfs may have been compressed)
PAYLOAD_MB=$((ROOT_TAR_MB + VAR_TAR_MB + HOME_TAR_MB))
# ext4 metadata / reserved blocks headroom
EXT4_OVERHEAD_MB=64

echo "Tar sizes: root=${ROOT_TAR_MB}M var=${VAR_TAR_MB}M home=${HOME_TAR_MB}M boot=${BOOT_TAR_MB}M (payload≈${PAYLOAD_MB}M)"

OVERHEAD_MB=$((EFI_MB + BOOT_MB + 4))
ROOT_MB=$((DISK_MB - OVERHEAD_MB))
# Need room for uncompressed payload + MTV free space (payload already includes used data)
NEED_ROOT_MB=$((PAYLOAD_MB + MIN_FREE_MB + EXT4_OVERHEAD_MB))
# Also never go below virt-df used + min free (when tars are sparse/weird)
if (( USED_ROOT_MB + MIN_FREE_MB + EXT4_OVERHEAD_MB > NEED_ROOT_MB )); then
  NEED_ROOT_MB=$((USED_ROOT_MB + MIN_FREE_MB + EXT4_OVERHEAD_MB))
fi

echo "Measured btrfs root used≈${USED_ROOT_MB} MiB, boot used≈${USED_BOOT_MB} MiB"
echo "Target disk=${DISK_MB} MiB → EFI=${EFI_MB} boot=${BOOT_MB} root=${ROOT_MB} (need≥${NEED_ROOT_MB})"

if (( ROOT_MB < NEED_ROOT_MB )); then
  SUGGEST=$((NEED_ROOT_MB + OVERHEAD_MB + 32))
  if (( SUGGEST > DISK_MB_MAX )); then
    SUGGEST_MSG="measured need ≈${SUGGEST} MiB exceeds disk_mb_max=${DISK_MB_MAX}; raise disk_mb_max only if intentional"
  else
    SUGGEST_MSG="re-run with: -e disk_mb=${SUGGEST}"
  fi
  cat >&2 <<EOF
ERROR: Cannot fit customized Cloud Base into disk_mb=${DISK_MB}.

  Btrfs reported used:    ${USED_ROOT_MB} MiB (may be compressed)
  Uncompressed payload:   ${PAYLOAD_MB} MiB (root+var+home tars)
  MTV min free:           ${MIN_FREE_MB} MiB
  Partition overhead:     ${OVERHEAD_MB} MiB (EFI ${EFI_MB} + /boot ${BOOT_MB} + GPT)
  Root space available:   ${ROOT_MB} MiB
  Root space required:    ${NEED_ROOT_MB} MiB

${SUGGEST_MSG}
EOF
  exit 1
fi

if (( USED_BOOT_MB + 32 > BOOT_MB )); then
  echo "ERROR: /boot used (${USED_BOOT_MB} MiB) does not fit fedora_boot_mb=${BOOT_MB}. Raise fedora_boot_mb." >&2
  exit 1
fi

echo "=== Creating ${DISK_MB} MiB destination qcow2 ==="
qemu-img create -f qcow2 "$DST" "${DISK_MB}M"

SECTOR=512
START=2048
EFI_SECS=$((EFI_MB * 1024 * 1024 / SECTOR))
BOOT_SECS=$((BOOT_MB * 1024 * 1024 / SECTOR))
TOTAL_SECS=$((DISK_MB * 1024 * 1024 / SECTOR))
LAST_USABLE=$((TOTAL_SECS - 2048 - 1))

EFI_START=$START
EFI_END=$((EFI_START + EFI_SECS - 1))
BOOT_START=$((EFI_END + 1))
BOOT_END=$((BOOT_START + BOOT_SECS - 1))
ROOT_START=$((BOOT_END + 1))
ROOT_END=$LAST_USABLE

if (( ROOT_END <= ROOT_START )); then
  echo "ERROR: partition math failed (ROOT_END=$ROOT_END ROOT_START=$ROOT_START)" >&2
  exit 1
fi

echo "GPT layout: EFI ${EFI_START}-${EFI_END}, boot ${BOOT_START}-${BOOT_END}, root ${ROOT_START}-${ROOT_END}"

# Build guestfish script so optional /var and /home tars are only imported when present
GF_SCRIPT="$WORK/repack-guestfish.cmd"
cat >"$GF_SCRIPT" <<EOF
run
part-init /dev/sda gpt
part-add /dev/sda p ${EFI_START} ${EFI_END}
part-add /dev/sda p ${BOOT_START} ${BOOT_END}
part-add /dev/sda p ${ROOT_START} ${ROOT_END}
part-set-gpt-type /dev/sda 1 C12A7328-F81F-11D2-BA4B-00A0C93EC93B
part-set-gpt-type /dev/sda 2 0FC63DAF-8483-4772-8E79-3D69D8477DE4
part-set-gpt-type /dev/sda 3 0FC63DAF-8483-4772-8E79-3D69D8477DE4
mkfs vfat /dev/sda1 label:ESP
mkfs ext4 /dev/sda2 label:BOOT
mkfs ext4 /dev/sda3 label:ROOT
mount /dev/sda3 /
tar-in ${ROOT_TAR} /
EOF

if [[ "$HAVE_VAR" -eq 1 ]]; then
  cat >>"$GF_SCRIPT" <<EOF
mkdir-p /var
tar-in ${VAR_TAR} /var
EOF
fi
if [[ "$HAVE_HOME" -eq 1 ]]; then
  cat >>"$GF_SCRIPT" <<EOF
mkdir-p /home
tar-in ${HOME_TAR} /home
EOF
fi

cat >>"$GF_SCRIPT" <<EOF
mkdir-p /boot
mount /dev/sda2 /boot
tar-in ${BOOT_TAR} /boot
mkdir-p /boot/efi
mount /dev/sda1 /boot/efi
tar-in ${EFI_TAR} /boot/efi
EOF

guestfish -a "$DST" <"$GF_SCRIPT"

echo "=== Fixing fstab, usr-merge links, GRUB; verifying OS files ==="
guestfish -a "$DST" <<'EOF'
run
mount /dev/sda3 /
mount /dev/sda2 /boot
mount /dev/sda1 /boot/efi
write /etc/fstab "LABEL=ROOT / ext4 defaults,x-systemd.device-timeout=0 1 1\nLABEL=BOOT /boot ext4 defaults 1 2\nLABEL=ESP /boot/efi vfat umask=0077,shortname=winnt 0 2\n"
# Fedora usr-merge — broken absolute symlinks after tar break libguestfs inspection / boot
sh "ln -sfn usr/bin /bin"
sh "ln -sfn usr/sbin /sbin"
sh "ln -sfn usr/lib /lib"
sh "ln -sfn usr/lib64 /lib64"
sh "test -e /etc/os-release"
sh "test -e /usr/lib/systemd/systemd || test -e /sbin/init"
sh "test -e /etc/fedora-release || ln -sf os-release /etc/fedora-release"
command "grub2-mkconfig -o /boot/grub2/grub.cfg"
sh "grub2-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=fedora --recheck --no-nvram || true"
sh "test -f /boot/efi/EFI/fedora/grubx64.efi || test -f /boot/efi/EFI/BOOT/BOOTX64.EFI"
touch /.autorelabel
EOF

echo "=== Verify os-release via explicit mount (no inspection) ==="
virt-cat -a "$DST" -m /dev/sda3:/ /etc/os-release | tee "$WORK/os-release.txt"
grep -q '^ID=fedora' "$WORK/os-release.txt"

echo "=== libguestfs OS inspection (required for MTV / virt-v2v) ==="
# Avoid virt-customize --selinux-relabel here: it requires inspection and can
# no-op/fail confusingly on freshly assembled disks. First boot .autorelabel handles it.
if ! virt-inspector -a "$DST" >"$WORK/inspector.xml" 2>"$WORK/inspector.err"; then
  echo "ERROR: virt-inspector failed — MTV will not convert this disk." >&2
  cat "$WORK/inspector.err" >&2 || true
  echo "--- filesystems ---" >&2
  virt-filesystems -a "$DST" -h --all --long >&2 || true
  exit 1
fi
if ! grep -q 'fedora\|linux' "$WORK/inspector.xml"; then
  echo "ERROR: virt-inspector produced no Fedora/linux OS record:" >&2
  cat "$WORK/inspector.xml" >&2 || true
  exit 1
fi
echo "virt-inspector OK"

echo "=== Post-repack free space ==="
virt-df -h -a "$DST" | tee "$WORK/measure-after.txt"

AVAIL_ROOT_MB="$(awk -F, '
  NR > 1 && $NF == "/" {
    printf "%d", int(($5 + 0) / 1024)
    exit
  }
' <(virt-df -a "$DST" --csv))"

# Fallback: available on /dev/sda3 when mountpoint not annotated
if [[ -z "${AVAIL_ROOT_MB}" ]]; then
  AVAIL_ROOT_MB="$(awk -F, '
    NR > 1 && $1 ~ /sda3/ {
      printf "%d", int(($5 + 0) / 1024)
      exit
    }
  ' <(virt-df -a "$DST" --csv))"
fi

if [[ -n "${AVAIL_ROOT_MB}" ]]; then
  echo "Available on /=${AVAIL_ROOT_MB} MiB (need≥${MIN_FREE_MB})"
  if (( AVAIL_ROOT_MB < MIN_FREE_MB )); then
    echo "ERROR: free space ${AVAIL_ROOT_MB} MiB < fedora_min_free_mb=${MIN_FREE_MB} after repack." >&2
    echo "Bump disk_mb (≤ disk_mb_max=${DISK_MB_MAX}) and rebuild." >&2
    exit 1
  fi
else
  echo "WARNING: could not parse available space; continuing" >&2
fi

rm -f "$ROOT_TAR" "$BOOT_TAR" "$EFI_TAR" "$VAR_TAR" "$HOME_TAR" "$GF_SCRIPT"
echo "=== Repack complete: $DST ==="
qemu-img info "$DST"
