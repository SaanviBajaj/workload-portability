#!/bin/sh
echo "=== todo-db startup $(date) ==="

i=0
while [ "$i" -lt 60 ]; do
  ip -4 addr show 2>/dev/null | grep -q 'inet ' && break
  i=$((i + 1))
  sleep 1
done

if ! podman image exists {{ todo_db_image }}; then
  echo "ERROR: container image missing from VMDK — rebuild with build-fedora-cloud-vms.yml"
  exit 1
fi

podman rm -f todo-db 2>/dev/null || true
if ! podman run -d --name todo-db \
  --network host \
  {{ todo_db_image }}; then
  echo "ERROR: podman run failed"
  exit 1
fi

echo "=== todo-db started $(date) ==="
podman ps -a
