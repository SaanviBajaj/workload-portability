[Unit]
# Stripped installroot guests can fail systemd-detect-virt briefly; without this
# ConditionVirtualization=vmware leaves vmtoolsd inactive and govc cannot see IPs.
ConditionVirtualization=

[Service]
# Prefer simple foreground mode so systemd tracks the process reliably
ExecStart=
ExecStart=/usr/bin/vmtoolsd -n
Type=simple
Restart=always
RestartSec=3
ExecStartPre=-/usr/sbin/modprobe fuse
ExecStartPre=-/usr/sbin/modprobe vmw_vmci
ExecStartPre=-/usr/sbin/modprobe vsock
ExecStartPre=-/usr/sbin/modprobe vmw_vsock_vmci_transport
