#!/bin/bash
set -euo pipefail

echo "=== todo-web startup $(date) ==="
echo "DB_HOST={{ db_host }} DB_PORT={{ db_port }}"

/usr/local/bin/prepare-podman-net
/usr/local/bin/ensure-dns

i=0
while [ "$i" -lt 60 ]; do
  ip -4 addr show eth0 2>/dev/null | grep -q 'inet ' && break
  i=$((i + 1))
  sleep 1
done

if ! podman image exists {{ todo_web_image }}; then
  echo "ERROR: container image missing from VMDK — rebuild with ansible-playbook build-fedora-minimal-vms.yml"
  exit 1
fi

podman rm -f todo-web 2>/dev/null || true
if ! podman run -d --name todo-web \
  --network host \
  -e DB_HOST={{ db_host }} \
  -e DB_PORT={{ db_port }} \
  {{ todo_web_image }}; then
  echo "ERROR: podman run failed"
  exit 1
fi

iptables -t nat -C PREROUTING -p tcp --dport 80 -j REDIRECT --to-ports 8080 2>/dev/null || \
  iptables -t nat -A PREROUTING -p tcp --dport 80 -j REDIRECT --to-ports 8080

echo "=== todo-web started $(date) ==="
podman ps -a
ss -tlnp | grep -E ':80|:8080' || true
