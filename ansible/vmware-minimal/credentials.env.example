# Copy to credentials.env and fill in your sandbox values.
# Pass to ansible-playbook with: -e @credentials.env

govc_url: "https://vcsnsx-vc.infra.demo.redhat.com"
govc_username: "sandbox-XXXXX@demo"
govc_password: "YourPasswordHere"
govc_insecure: true
govc_datastore: "workload_share_XXXXX"

vm_network: "segment-sandbox-XXXXX"
vm_folder: "/SDDC-Datacenter/vm/Workloads/sandbox-XXXXX"
datastore_base: "Workload-Portability"

db01_vm_name: "todo-db"
web01_vm_name: "todo-web"

# Optional static IPs — use if govc cannot discover IPs via VMware Tools
# db01_static_ip: "192.168.108.50"
# web01_static_ip: "192.168.108.51"

# Optional: offline image tars on bastion when quay.io denies pulls
# todo_db_image_tar: "/root/minimal-build/todo-db.tar"
# todo_web_image_tar: "/root/minimal-build/todo-web.tar"

# Optional: set if todo-db already exists and you only want to rebuild todo-web
# db_host: "192.168.108.25"
