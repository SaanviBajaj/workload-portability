#!/usr/bin/env bash
# Use host qemu-img when available; otherwise run via Podman (no dnf on bastion).
set -euo pipefail

BUILD_DIR="{{ alpine_build_dir }}"
CONTAINER_IMAGE="{{ qemu_img_image }}"

if command -v qemu-img >/dev/null 2>&1; then
  exec qemu-img "$@"
fi

CONTAINER_ARGS=()
for arg in "$@"; do
  if [[ "${arg}" == "${BUILD_DIR}"* ]]; then
    CONTAINER_ARGS+=("/work${arg#${BUILD_DIR}}")
  else
    CONTAINER_ARGS+=("${arg}")
  fi
done

exec podman run --rm \
  --user 0:0 \
  --security-opt label=disable \
  -v "${BUILD_DIR}:/work" \
  -w /work \
  "${CONTAINER_IMAGE}" \
  sh -ec "apk add --no-cache qemu-img >/dev/null 2>&1 && exec qemu-img $(printf '%q ' "${CONTAINER_ARGS[@]}")"
