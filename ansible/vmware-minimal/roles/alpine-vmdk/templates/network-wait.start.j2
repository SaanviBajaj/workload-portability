#!/bin/sh
# VMware NIC drivers load after boot — do not start networking until eth0 exists.
i=0
while [ "$i" -lt 60 ]; do
  if ip link show eth0 >/dev/null 2>&1; then
    rc-service networking start
    exit 0
  fi
  i=$((i + 1))
  sleep 1
done
echo "network-wait: eth0 not found after 60s" >&2
exit 1
