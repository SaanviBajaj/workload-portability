#!/bin/sh
# VMware NIC drivers load after boot — wait for eth0, then DHCP.
modprobe vmxnet3 2>/dev/null
modprobe e1000 2>/dev/null

i=0
while [ "$i" -lt 60 ]; do
  if ip link show eth0 >/dev/null 2>&1; then
    break
  fi
  i=$((i + 1))
  sleep 1
done

if ! ip link show eth0 >/dev/null 2>&1; then
  echo "network-wait: eth0 not found after 60s" >&2
  exit 1
fi

ip link set eth0 up
rc-service networking start

j=0
while [ "$j" -lt 45 ]; do
  if ip -4 addr show eth0 | grep -q 'inet '; then
    exit 0
  fi
  j=$((j + 1))
  sleep 1
done

# Last resort: run udhcpc directly if ifupdown-ng did not get a lease.
udhcpc -i eth0 -t 5 -T 3 -n -q 2>/dev/null || true
exit 0
