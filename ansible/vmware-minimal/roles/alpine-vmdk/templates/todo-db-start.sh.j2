#!/bin/sh
mount -o remount,rw / 2>/dev/null || true

echo "=== todo-db startup $(date) ==="

/usr/local/bin/prepare-podman-net

i=0
while [ "$i" -lt 60 ]; do
  ip -4 addr show eth0 2>/dev/null | grep -q 'inet ' && break
  i=$((i + 1))
  sleep 1
done

if ! podman image exists {{ todo_db_image }}; then
  echo "ERROR: container image missing from VMDK — rebuild with ansible-playbook build-minimal-vms.yml"
  exit 1
fi

podman rm -f todo-db 2>/dev/null || true
if ! podman run -d --name todo-db \
  --network host \
  {{ todo_db_image }}; then
  echo "ERROR: podman run failed"
  exit 1
fi

echo "=== todo-db started $(date) ==="
podman ps -a
