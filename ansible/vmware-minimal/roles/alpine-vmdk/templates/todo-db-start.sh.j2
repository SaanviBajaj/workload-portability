#!/bin/sh
LOG=/var/log/todo-db.start.log
IMAGE_TAR=/var/images/todo-db.tar
{
  echo "=== todo-db startup $(date) ==="
  /usr/local/bin/prepare-podman-net
  if [ -f "$IMAGE_TAR" ]; then
    echo "Loading embedded image from $IMAGE_TAR"
    podman load -i "$IMAGE_TAR"
  elif ! podman image exists {{ todo_db_image }}; then
    /usr/local/bin/ensure-dns
    if ! podman pull {{ todo_db_image }}; then
      echo "ERROR: podman pull failed and no embedded image at $IMAGE_TAR"
      exit 1
    fi
  fi
  podman rm -f todo-db 2>/dev/null || true
  if ! podman run -d --name todo-db \
    --network host \
    {{ todo_db_image }}; then
    echo "ERROR: podman run failed"
    exit 1
  fi
  echo "=== todo-db started $(date) ==="
  podman ps -a
} >>"$LOG" 2>&1
