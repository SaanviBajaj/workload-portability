#!/bin/sh
LOG=/var/log/todo-db.start.log
{
  echo "=== todo-db startup $(date) ==="
  /usr/local/bin/ensure-dns
  /usr/local/bin/prepare-podman-net
  sleep 30
  if ! podman pull {{ todo_db_image }}; then
    echo "ERROR: podman pull failed"
    exit 1
  fi
  podman rm -f todo-db 2>/dev/null || true
  if ! podman run -d --name todo-db \
    --network host \
    {{ todo_db_image }}; then
    echo "ERROR: podman run failed"
    exit 1
  fi
  echo "=== todo-db started $(date) ==="
  podman ps -a
} >>"$LOG" 2>&1
